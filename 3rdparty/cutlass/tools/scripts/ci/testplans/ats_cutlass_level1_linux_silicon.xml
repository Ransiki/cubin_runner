<config version="1.0">
    <group>
        <identifier>CUTLASS_LINUX_SILICON_L1</identifier>
        <flow>cutlass.ExecTests</flow>
        <test>
            <identifier>cutlass.ExecTests</identifier>
            <plugin>simple-target</plugin>
            <command>
              <![CDATA[
                cd {target-mount-root}/build && 
                bash ./tools/scripts/ci/testplans/ats_cutlass_level1_linux_silicon.sh && 
                echo CUTLASS_LINUX_SILICON_L1_PASSED
              ]]>
            </command>
            <regex-pass>CUTLASS_LINUX_SILICON_L1_PASSED</regex-pass>
            <execute-timeout>1800</execute-timeout>
            <os>docker.*</os>
        </test>
    </group>
</config>
