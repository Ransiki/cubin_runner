// Transpose tests
"NCHW2"                                     = transform                   *  n:128  *  c:3  *  h:224  *  w:224  *  formatIn:0
"NHWC2"                                     = transform                   *  n:128  *  c:3  *  h:224  *  w:224  *  formatIn:1
"TNV2NVT"                                   = transform                   *  dim:2  *  dimA:"30,128,512"
"5D"                                        = transform * slow_exclude    *  dim:3  *  dimA:"64,64,64,64,64"
"6D"                                        = transform * slow_exclude    *  dim:4  *  dimA:"8,32,32,32,32,32"

"mobileNet_conv0"                       = convolution                 * dimA:"1,32,112,112" * filtA:"32,1,3,3" * pad_h:1 * pad_w:1 * u:1 * v:1 * dynamic_batch_size * groupCount:32
"mobileNet_conv1"                       = convolution                 * dimA:"1,64,112,112" * filtA:"64,1,3,3" * pad_h:1 * pad_w:1 * u:2 * v:2 * dynamic_batch_size * groupCount:64
"mobileNet_conv2"                       = convolution                 * dimA:"1,128,56,56" * filtA:"128,1,3,3" * pad_h:1 * pad_w:1 * u:1 * v:1 * dynamic_batch_size * groupCount:128
"mobileNet_conv3"                       = convolution                 * dimA:"1,128,56,56" * filtA:"128,1,3,3" * pad_h:1 * pad_w:1 * u:2 * v:2 * dynamic_batch_size * groupCount:128
"mobileNet_conv4"                       = convolution                 * dimA:"1,256,28,28" * filtA:"256,1,3,3" * pad_h:1 * pad_w:1 * u:1 * v:1 * dynamic_batch_size * groupCount:256
"mobileNet_conv5"                       = convolution                 * dimA:"1,256,28,28" * filtA:"256,1,3,3" * pad_h:1 * pad_w:1 * u:2 * v:2 * dynamic_batch_size * groupCount:256
"mobileNet_conv6"                       = convolution                 * dimA:"1,512,14,14" * filtA:"512,1,3,3" * pad_h:1 * pad_w:1 * u:1 * v:1 * dynamic_batch_size * groupCount:512
"mobileNet_conv7"                       = convolution                 * dimA:"1,512,14,14" * filtA:"512,1,3,3" * pad_h:1 * pad_w:1 * u:2 * v:2 * dynamic_batch_size * groupCount:512
"mobileNet_conv8"                       = convolution                 * dimA:"1,1024,7,7" * filtA:"1024,1,3,3" * pad_h:1 * pad_w:1 * u:1 * v:1 * dynamic_batch_size * groupCount:1024


"Bug_2024454"                           = convolution * dimA:"512,512,16,1" * filtA:"1024,512,3,1" * pad_h:0 * pad_w:0 * u:1 * v:1 * dynamic_batch_size

"Bug_2405494_bn_n_limit"                = R:bnf * algo:0 * P:s * dimA:"131071,256,2,1" * formatIn:0 * common_flags

"Bug_2445829_n32_support"               = R:convBiasAct * Pin:b * Pout:b * Pcomp:b * algo:1 * filtFormat:2 * formatIn:2 * formatOut:2 * p:i * dimA:"16,32,64,64" * filtA:"32,32,16,16" * padA:"1,1" * nc:32 * common_flags

"pgan_splitK_conv0" = convolution_splitK * dimA:"1,256,64,64" * filtA:"512,256,4,4" * u:2 * v:2
"pgan_splitK_conv1" = convolution_splitK * dimA:"1,512,32,32" * filtA:"512,512,3,3" * u:1 * v:1
"pgan_splitK_conv2" = convolution_splitK * dimA:"1,512,32,32" * filtA:"512,512,4,4" * u:2 * v:2
"pgan_splitK_conv3" = convolution_splitK * dimA:"1,512,16,16" * filtA:"512,512,3,3" * u:1 * v:1
"pgan_splitK_conv4" = convolution_splitK * dimA:"1,512,16,16" * filtA:"512,512,4,4" * u:2 * v:2
"pgan_splitK_conv5" = convolution_splitK * dimA:"1,512,8,8"   * filtA:"512,512,3,3" * u:1 * v:1
"pgan_splitK_conv6" = convolution_splitK * dimA:"1,512,8,8"   * filtA:"512,512,4,4" * u:2 * v:2

// Adding hikvision layers used for cudnn vs. tensor rt perf comparison. Bug 200428707 (IMMA perf comparison) Bug 200437710 (DP4 perf comparison)
