<2D_1x1>
    dimA:"1,64,200,272 * filtA:"64,64,1,1    * padA:"0,0" * u:1 * v:1

<2D_3x3>
    dimA:"16,32,9,9    * filtA:"32,32,3,3    * padA:"1,1" * u:1 * v:1
    dimA:"1,80,73,73   * filtA:"192,80,3,3   * pad_h:0 * pad_w:0 * u:1 * v:1

<2D_5x5>
    dimA:"1,64,27,27   * filtA:"192,64,5,5   * pad_h:2 * pad_w:2 * u:1 * v:1

<2D_11x11>
