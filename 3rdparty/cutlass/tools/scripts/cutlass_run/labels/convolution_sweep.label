<eris_exclude: !ERIS>
    *

<slow_exclude: !SLOW>
    *

// Flags used by all layers
<common_flags>
    A:1  *  B:0  *  b: * n:8 * csv:

<format_000>
    formatIn:0 * filtFormat:0 * formatOut:0

<format_111>
    formatIn:1 * filtFormat:1 * formatOut:1

<format_222>
    formatIn:2 * filtFormat:2 * formatOut:2

<type_HHH>
    Pin:h * Pcomp:h * Pout:h

<type_HSH>
    Pin:h * Pcomp:s * Pout:h

<type_SSS>
    Pin:s * Pcomp:s * Pout:s

<type_BBI>
    Pin:b * Pout:b * p:i

// we need accurately control the command and make it easy for adding, removing, modifying or triaging
// conv + algo0
<conv_algo0_math0_format000_typehhh>
    R: conv   * algo: 0                * Pmath:0 * format_000 * type_HHH
<conv_algo0_math0_format000_typehsh>
    R: conv   * algo: 0                * Pmath:0 * format_000 * type_HSH
<conv_algo0_math0_format000_typesss>
    R: conv   * algo: 0                * Pmath:0 * format_000 * type_SSS
<conv_algo0_math0_format111_typehhh>
    R: conv   * algo: 0                * Pmath:0 * format_111 * type_HHH
<conv_algo0_math0_format111_typehsh>
    R: conv   * algo: 0                * Pmath:0 * format_111 * type_HSH
<conv_algo0_math0_format111_typesss>
    R: conv   * algo: 0                * Pmath:0 * format_111 * type_SSS
<conv_algo0_math1_format000_typehhh>
    R: conv   * algo: 0                * Pmath:1 * format_000 * type_HHH
<conv_algo0_math1_format000_typehsh>
    R: conv   * algo: 0                * Pmath:1 * format_000 * type_HSH
<conv_algo0_math1_format000_typesss>
    R: conv   * algo: 0                * Pmath:1 * format_000 * type_SSS
<conv_algo0_math1_format111_typehhh>
    R: conv   * algo: 0                * Pmath:1 * format_111 * type_HHH
<conv_algo0_math1_format111_typehsh>
    R: conv   * algo: 0                * Pmath:1 * format_111 * type_HSH
<conv_algo0_math1_format111_typesss>
    R: conv   * algo: 0                * Pmath:1 * format_111 * type_SSS
<conv_algo0_format111_typebbi>
    R: conv * algo: 0                  *           format_111 * type_BBI
<conv_algo0_format222_typebbi>
    R: conv * algo: 0                  *           format_222 * type_BBI

