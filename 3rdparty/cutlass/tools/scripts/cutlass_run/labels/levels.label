<L3_convBiasAct_InOutActMix_IDENTITY_all:L3,L4>
    // INT8_EXT_CONFIG & UINT8_EXT_CONFIG
    Pin:b,u * formatIn:1 * Pout:s * formatOut:1 * Pcomp:b * filtFormat:1 * activFloor: * p:i
    Pin:u * formatIn:1 * Pout:s * formatOut:1 * Pcomp:b * filtFormat:1 * p:i
    // INT8_CONFIG & UINT8_CONFIG
    Pin:b,u * formatIn:1 * Pout:b * formatOut:1 * Pcomp:b * filtFormat:1 * activFloor: * p:i
    Pin:u * formatIn:1 * Pout:b * formatOut:1 * Pcomp:b * filtFormat:1 * p:i
    // INT8x4_CONFIG & UINT8x4_CONFIG
    Pin:b,u * formatIn:2 * Pout:b * formatOut:2 * Pcomp:b * filtFormat:2 * activFloor: * p:i
    Pin:b,u * formatIn:2 * Pout:b * formatOut:2 * Pcomp:b * filtFormat:2 * activFloor: * p:i
    Pin:u * formatIn:2 * Pout:b * formatOut:2 * Pcomp:b * filtFormat:2 * p:i
    // INT8x4_EXT_CONFIG & UINT8x4_EXT_CONFIG
    Pin:b,u * formatIn:2 * Pout:s * formatOut:1 * Pcomp:b * filtFormat:2 * activFloor: * p:i
    Pin:u * formatIn:2 * Pout:s * formatOut:1 * Pcomp:b * filtFormat:2 * p:i
    // FLOAT_CONFIG
    Pin:s * formatIn:0 * Pout:s * formatOut:0 * Pcomp:s * filtFormat:0 * activFloor:
    Pin:s * formatIn:1 * Pout:s * formatOut:1 * Pcomp:s * filtFormat:1 * activFloor:
    // DOUBLE_CONFIG
    Pin:d * formatIn:0 * Pout:d * formatOut:0 * Pcomp:d * filtFormat:0 * activFloor:
    Pin:d * formatIn:1 * Pout:d * formatOut:1 * Pcomp:d * filtFormat:1 * activFloor:
    // TRUE_HALF_CONFIG
    Pin:h * formatIn:0 * Pout:h * formatOut:0 * Pcomp:h * filtFormat:0 * activFloor:
