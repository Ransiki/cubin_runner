<L2_wgrad_fft1_tiling:L2,L3,L4>
    // Failing test bug 2072856
    A:1 * B:0 * dim:2 * dimA:"1,1,2,257"   * filtA:"1,1,2,11"  * n:1   * c:1   * k:1  * b:
    A:1 * B:0 * dim:2 * dimA:"1,1,2,257"   * filtA:"1,1,2,11"  * n:20  * c:6   * k:10 * b:
    A:4 * B:1 * dim:2 * dimA:"1,1,2,33"    * filtA:"1,1,2,11"  * n:728 * c:96  * k:1  * b:
    // Small image
    A:3 * B:2 * dim:2 * dimA:"1,1,1,14"    * filtA:"1,1,1,3"   * n:256 * c:32  * k:16
    A:3 * B:2 * dim:2 * dimA:"1,1,14,1"    * filtA:"1,1,3,1"   * n:256 * c:32  * k:16
    // Large image, two sub-tiles
    A:1 * B:1 * dim:2 * dimA:"1,1,1,260"   * filtA:"1,1,1,50"  * n:16  * c:3   * k:10
    A:1 * B:1 * dim:2 * dimA:"1,1,260,1"   * filtA:"1,1,50,1"  * n:16  * c:3   * k:10
    // Large image, eight sub-tiles
    A:1 * B:2 * dim:2 * dimA:"1,1,1,300"   * filtA:"1,1,1,51"  * n:3   * c:2   * k:8
    A:1 * B:2 * dim:2 * dimA:"1,1,300,1"   * filtA:"1,1,51,1"  * n:3   * c:2   * k:8
    // 1D filter max 256
    A:1 * B:2 * dim:2 * dimA:"1,1,1,262"   * filtA:"1,1,1,7"   * n:128 * c:2   * k:8
    A:1 * B:2 * dim:2 * dimA:"1,1,262,1"   * filtA:"1,1,7,1"   * n:128 * c:2   * k:8
    // 2D x 1D -> 1D
    A:1 * B:2 * dim:2 * dimA:"1,1,256,80"  * filtA:"1,1,256,1" * n:2   * c:3   * k:4
    A:1 * B:2 * dim:2 * dimA:"1,1,256,1"   * filtA:"1,1,256,1" * n:2   * c:3   * k:4
    // Include padding
    A:1 * B:2 * dim:2 * dimA:"1,1,1,300"   * filtA:"1,1,1,100" * n:10  * c:30  * k:20 * padA:"0,21"
    A:1 * B:2 * dim:2 * dimA:"1,1,300,1"   * filtA:"1,1,100,1" * n:10  * c:30  * k:20 * padA:"10,0"
    // Likely fft1 32-points
    dimA:"8,14,20,1500" * filtA:"18,14,20,1450"
    dimA:"8,14,1500,10" * filtA:"18,14,1450,10"
    // Likely fft1 256-points
    dimA:"8,14,20,1200" * filtA:"18,14,20,800"
    dimA:"8,14,1200,16" * filtA:"18,14,800,16"

<L3_Pinb_Pcompb_pi_largeK:L3,L4>
