    n:2 * c:17 * k:44 * B:0 * x:
    n:3 * c:3  * k:32 * r:5 * s:5 * x:

<L3_groupedConv_variousDims:L3,L4>

    padA:"0,1" * dim:2 * dimA:"2,32,15,13"  * groupCount:2 * filtA:"64,16,9,9"
    padA:"2,1" * dim:2 * dimA:"5,9,9,12"   * groupCount:3 * filtA:"12,3,6,3"
    padA:"2,3" * dim:2 * dimA:"8,15,10,8"  * groupCount:5 * filtA:"10,3,5,6"
    padA:"2,1" * dim:2 * dimA:"4,16,12,9" * groupCount:8 * filtA:"16,2,8,5"

    padA:"2,1" * dim:2 * dimA:"6,6,7,10"  * groupCount:6 * filtA:"6,1,1,1"   * formatOut:0 * formatIn:0
    padA:"0,0" * dim:2 * dimA:"7,7,6,15"  * groupCount:7 * filtA:"7,1,3,3"   * formatOut:0 * formatIn:0
    padA:"2,3" * dim:2 * dimA:"4,16,15,7" * groupCount:4 * filtA:"8,4,3,3"   * formatOut:0 * formatIn:0
    padA:"0,0" * dim:2 * dimA:"2,9,12,9"  * groupCount:3 * filtA:"3,3,1,1"   * formatOut:0 * formatIn:0

    // Bug #2011118
    padA:"0,0" * dim:2 * dimA:"1,4,4,5"     * groupCount:2 * filtA:"2,2,2,3"   * formatOut:0 * formatIn:0
    padA:"0,0" * dim:2 * dimA:"1,2,4,5"     * groupCount:2 * filtA:"4,1,2,3"   * formatOut:0 * formatIn:0

    padA:"2,1,2" * dim:3 * dimA:"2,12,8,6,3"  * groupCount:2 * filtA:"18,6,6,4,3"
    padA:"2,1,4" * dim:3 * dimA:"5,9,7,8,7"   * groupCount:3 * filtA:"12,3,5,3,6"
