    rnnInputSize:1024 * rnnNumLayers:2 * rnnMiniBatch:48 * rnnSeqLength:2 * rnnHiddenSize:1024 * rnnTestVariableMinibatch:0,1 * rnnbidirectional:0 * rnnSkipInput:0,1 * rnnPersistent:2 * rnnTestDropout:0 * mode:2 * Pmath:0,1
    //pattern: .*rnnbidirectional1.*rnnSkipInput0.*rnnPersistent0.*rnnTestDropout0.*mode2.* total 12 cases
    rnnInputSize:1024 * rnnNumLayers:2 * rnnMiniBatch:48 * rnnSeqLength:2 * rnnHiddenSize:1024 * rnnTestVariableMinibatch:0,1 * rnnbidirectional:1 * rnnSkipInput:0 * rnnPersistent:0 * rnnTestDropout:0 * mode:2 * Pmath:0,1
