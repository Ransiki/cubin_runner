<Pdhs>
    P:d,h,s

<Pbdhs>
    P:b,d,h,s

<Pb>
    P:b

<Pbhs>
    P:b,h,s

<Phs>
    P:h,s

<Ph>
    P:h

<Ps>
    P:s

<Pin_Pout_hsb>
    Pin:h       *  Pout:s
    Pin:s       *  Pout:h
    Pin:b       *  Pout:s
    Pin:s       *  Pout:b

// Bug 200428771:[test coverage development] investigate and improve cuDNN LRN related test
<Pd>
    P:d

// Define labels for requiring specific levels
<L0_req:L0,L1,L2,L3,L4>
    *

<L1_req:L1,L2,L3,L4>
    *

<L2_req:L2,L3,L4>
    *

<L3_req:L3,L4>
    *

<L4_req:L4>
    *


// Run both cross-correlation & convolution
<conv_corr>
    *
    x:

// Run all Gets, Finds & findEx's
<get_find_findEx>
    R:findFwdAlgo,findBwdDataAlgo,findBwdFilterAlgo
    R:findFwdAlgo,findBwdDataAlgo,findBwdFilterAlgo * memlimit:-1
    R:getFwdAlgo,getBwdDataAlgo,getBwdFilterAlgo

<L1_batch4:L1,L2,L3,L4>
    n:4
    n:4 * b:

<L4_n4:L4>
    n:4
    n:4 * b:

<L4_Pdhs_batch4>
    Pdhs * L4_n4

<L4_Pb_batch4>
    Pb * L4_n4

<L4_Pbdhs_batch4>
    Pbdhs * L4_n4

<L4_Pin_Pout_hsb_batch4>
    Pin_Pout_hsb * L4_n4

<L1_L4_Pdhs_batch4>
    Phs * L1_batch4
    Pdhs * L4_n4

<L1_L4_Pbdhs_batch4>
    Phs * L1_batch4
    Pbdhs * L4_n4
<large_window_pool_dims>
    // Random tests (no -b); set Alpha/Beta for 3-D due to numeric error on AVERAGE
    dimA:"1,1,1,1024"    *  win_d:1  *  win_h:1  *  win_w:320 * convStrideA:1,1    *  dim:2
    dimA:"1,1,1,1,1024"  *  win_d:1  *  win_h:1  *  win_w:320 * convStrideA:1,2,1  *  dim:3  *  A:2  *  B:1

    // Specific tests (-b) to ensure packedness testing
    dimA:"1,1,1,1024"    *  win_d:1  *  win_h:1  *  win_w:320  *  convStrideA:"2,2"    *  b:  *  dim:2
    dimA:"1,1,1,1,1024"  *  win_d:1  *  win_h:1  *  win_w:320  *  convStrideA:"2,2,2"  *  b:  *  dim:3  *  A:1  *  B:2

    // Specific tests for max ordering (bug #1938557)
    dimA:"1,1,16,257"   *  win_d:1  *  win_h:1  *  win_w:257  *  p:1  *  u:1  *  v:1  *  mode:0  *  A:1  *  B:0  *  b:  *  dim:2
    dimA:"1,1,1,1,257"  *  win_d:1  *  win_h:1  *  win_w:257  *  p:1  *  u:1  *  v:1  *  mode:0  *  A:1  *  B:0  *  b:  *  dim:3

<large_window_pool_dims_for_vector_datatype>
    // Random tests (no -b); set Alpha/Beta for 3-D due to numeric error on AVERAGE
    dimA:"1,32,1,1024" *  win_h:1  *  win_w:320 * convStrideA:1,1    *  dim:2
    dimA:"1,32,1,1024" *  win_h:1  *  win_w:320 * convStrideA:1,2 *  A:2  *  B:1

    // Specific tests (-b) to ensure packedness testing
    dimA:"1,32,1,1024" *  win_d:1  *  win_h:1  *  win_w:320  *  convStrideA:"2,2"    *  b:  *  dim:2
    dimA:"1,32,1,1024" * win_h:1  *  win_w:320  *  convStrideA:"2,2"  *  b:  *  dim:2  *  A:1  *  B:2

    // Specific tests for max ordering
    dimA:"1,32,16,257" *  win_h:1  *  win_w:257  *  p:1  *  u:1  *  v:1 *  A:1  *  B:0  *  b:  *  dim:2
    dimA:"1,32,1,257" *  win_h:1  *  win_w:257  *  p:1  *  u:1  *  v:1 *  A:1  *  B:0  *  b:  *  dim:2

<all_pooling_formats>
    *
    formatIn:1 * formatOut:1
    formatIn:0 * formatOut:0

<vector_pooling_formats:L4>
    //for INT8x4
    formatIn:2 * formatOut:2
    //for INT8x32
    formatIn:2 * formatOut:2 * nc32:

<all_pooling_modes>
    R:poolf  *  mode:0,1,2
    R:poolb  *  mode:0,1,2,3

<vector_pooling_modes:L4>
    R:poolf * mode:0,1,2

<pooling_nan_formats:L4>
    //nonan
    *
    //initnan and dont propagate
    initnan:
    //initinan and propagate
    initnan: * propnan:

<pooling_window_sizes:L4>
    win_w:2,3 * win_h:2,3 * u:2,3 * v:2,3

<pooling_vector_diff_dimension_for_vect_x4_no_randomization:L4>
    n:5 * c:4,20 * h:20,87 * w:20,87       

<pooling_vector_diff_dimension_for_vect_x32_no_randomization:L4>
    n:5 * c:32,96 * h:20,87 * w:20,87       


<conv_variousDims>
    n:5

    r:1 * s:3
    r:3 * s:1

    n:4 * pad_w:3 * pad_h:3

    r:3 * s:5 * x:
    r:5 * s:3 * x:

    n:5 * pad_w:2 * pad_h:3 * x:
    n:5 * u:2     * v:2     * x:

    pad_h:1 * pad_w:1 * r:2 * s:3 * B:0

    n:6 * pad_h:3 * u:2 * v:3 * pad_w:2 * D:texoff_dbg=1
    n:6 * pad_h:3 * u:2 * v:3 * pad_w:2 * off:12

<divnorm_variousDims>
    dim:3 * dimA:"15,13,4,6,7" * N:100
    dim:3 * B:0                * dimA:"31,7,5,11,3" * N:20
    dim:2 * c:15               * h:1                * N:100    * w:1   * n:15
    dim:2 * c:35               * h:1                * N:100    * w:1   * n:35
    dim:2 * c:6                * h:6                * N:100    * w:6   * n:6
    dim:2 * c:1024             * h:1                * N:20     * w:1   * n:512
    dim:2 * c:8                * h:17               * N:20     * w:13  * n:8
    dim:2 * c:31               * b:                 * h:1      * n:35  * w:1
    dim:2 * c:32               * b:                 * h:1      * n:35  * w:1
    dim:2 * c:33               * b:                 * h:1      * n:35  * w:1
    dim:2 * c:63               * b:                 * h:1      * n:35  * w:1
    dim:2 * c:65               * b:                 * h:1      * n:35  * w:1
    dim:2 * c:64               * b:                 * h:1      * n:35  * B:0   * w:1
    dim:2 * c:8                * h:3                * inplace: * n:8   * w:5   * N:10
    dim:2 * c:25000            * ps:0.5             * h:1      * n:512 * p:r   * w:1  * pm:0

<L0_Pcomph_pi_nRange1to9:L0,L1,L2,L3,L4>
    Pcomp:h * p:i * n:1,2,8,9

<L0_Pcomph_pi_variousBatch:L0,L1,L2,L3,L4>
    n:1,64 * Pcomp:h * p:i
    n:32   * Pcomp:h * p:i   * x:
    n:100  * Pcomp:h * N:100 * iFilt:1

<L2_variousDims:L2,L3,L4>
