    rnnInputSize:1024 * rnnbidirectional:1 * rnnSkipInput:1   * rnnMiniBatch:100 * rnnPersistent:2 * mode:3 * rnnSeqLength:5 * rnnHiddenSize:1024

// Bug 200411847 addedd for RNN split in different levels in release test
<L1_SIMPLE_RNN:L1>
    mode:0 * rnnNumLayers:1 * rnnInputSize:64 * rnnHiddenSize:64 * rnnbidirectional:0 * rnnMiniBatch:4 * rnnSeqLength:4 * P:s * Pmath:0 * rnnPersistent:0 * rnnTestVariableMinibatch:0 * N:1 * rnnBiasMode:0,1,2,3

<RNN_ALGO0_IN_OUT_COMP_DATATYPE_MIX>
    Pin:h * Pout:h * Pcomp:h
    Pin:h * Pout:h * Pcomp:s
    Pin:s * Pout:s * Pcomp:s
    Pin:d * Pout:d * Pcomp:d

<RNN_persist_variable_mix>
    rnnPersistent:0 * RNN_ALGO0_IN_OUT_COMP_DATATYPE_MIX  * rnnTestVariableMinibatch:0,1 * rnnBiasMode:0,1,2,3
    rnnPersistent:1 * P:s,h * rnnTestVariableMinibatch:0
    rnnPersistent:2 * P:s,h,d * rnnTestVariableMinibatch:0

<L4_RNN_ALL_COMBINATIONS:L4>
    rnnNumLayers:3 * rnnInputSize:256 * rnnHiddenSize:256 * rnnbidirectional:0,1 * rnnMiniBatch:8 * rnnSeqLength:4 * Pmath:0,1,2 * RNN_persist_variable_mix * N:8

<L4_RNN_PROJ_FWD:L4>
    mode:2 * rnnPersistent:0 * Pmath:0,1 * rnnProjSizes:"128,0" * rnnHiddenSize:256 * rnnInputSize:256 * rnnSeqLength:32 * rnnNumLayers:4 * rnnMiniBatch:32 * rnnbidirectional:0,1 * rnnTestVariableMinibatch:0,1 * rnnSkipInput:0,1 * rnnRandNull:0 * P:s,h * N:30
    mode:2 * rnnPersistent:0 * Pmath:1 * rnnProjSizes:"1024,0" * rnnHiddenSize:8192 * rnnInputSize:1024 * rnnSeqLength:20 * rnnNumLayers:1 * rnnMiniBatch:128 * rnnbidirectional:0,1 * rnnSkipInput:0 * rnnRandNull:0 * P:h * b:

<L4_RNN_PROJ_BWD:L4>
    mode:2 * rnnPersistent:0 * Pmath:0,1 * rnnProjSizes:"128,0" * rnnHiddenSize:256 * rnnInputSize:256 * rnnSeqLength:32 * rnnNumLayers:4 * rnnMiniBatch:32 * rnnbidirectional:0,1 * rnnTestVariableMinibatch:0,1 * rnnSkipInput:0,1 * rnnRandNull:0 * P:s,h * N:30
    mode:2 * rnnPersistent:0 * Pmath:1 * rnnProjSizes:"1024,0" * rnnHiddenSize:8192 * rnnInputSize:1024 * rnnSeqLength:20 * rnnNumLayers:1 * rnnMiniBatch:128 * rnnbidirectional:0,1 * rnnSkipInput:0 * rnnRandNull:0 * P:h * b:

//RNN find support-1
<L4_RNN_find_1:L4>
    //pattern: .*rnnbidirectional0.*rnnPersistent0.*mode0.* total 56 cases
    rnnInputSize:1024 * rnnNumLayers:2 * rnnMiniBatch:48 * rnnSeqLength:2 * rnnHiddenSize:1024 * rnnTestVariableMinibatch:0,1 * rnnbidirectional:0 * rnnSkipInput:0,1 * rnnPersistent:0 * rnnTestDropout:0,1 * mode:0 * Pmath:0,1
    //pattern: .*rnnbidirectional0.*rnnPersistent0.*mode1.*  total 56 cases
    rnnInputSize:1024 * rnnNumLayers:2 * rnnMiniBatch:48 * rnnSeqLength:2 * rnnHiddenSize:1024 * rnnTestVariableMinibatch:0,1 * rnnbidirectional:0 * rnnSkipInput:0,1 * rnnPersistent:0 * rnnTestDropout:0,1 * mode:1 * Pmath:0,1
    //pattern: .*rnnbidirectional0.*rnnPersistent2.mode[01].*  total 112 cases
    rnnInputSize:1024 * rnnNumLayers:2 * rnnMiniBatch:48 * rnnSeqLength:2 * rnnHiddenSize:1024 * rnnTestVariableMinibatch:0,1 * rnnbidirectional:0 * rnnSkipInput:0,1 * rnnPersistent:2 * rnnTestDropout:0,1 * mode:0,1 * Pmath:0,1
    //pattern: .*rnnbidirectional1.*rnnSkipInput0.*rnnPersistent0.* total 56 cases
    rnnInputSize:1024 * rnnNumLayers:2 * rnnMiniBatch:48 * rnnSeqLength:2 * rnnHiddenSize:1024 * rnnTestVariableMinibatch:0,1 * rnnbidirectional:1 * rnnSkipInput:0 * rnnPersistent:0 * rnnTestDropout:0,1 * mode:0,1 * Pmath:0,1
    //pattern: .*rnnbidirectional1.*rnnSkipInput1.*rnnPersistent0.*rnnTestDropout0.*  total 32 cases
    rnnInputSize:1024 * rnnNumLayers:2 * rnnMiniBatch:48 * rnnSeqLength:2 * rnnHiddenSize:1024 * rnnTestVariableMinibatch:0,1 * rnnbidirectional:1 * rnnSkipInput:1 * rnnPersistent:0 * rnnTestDropout:0 * mode:0,1 * Pmath:0,1
    //pattern: .*rnnbidirectional1.*rnnSkipInput0.*rnnPersistent2.*mode0.* total 56 cases
    rnnInputSize:1024 * rnnNumLayers:2 * rnnMiniBatch:48 * rnnSeqLength:2 * rnnHiddenSize:1024 * rnnTestVariableMinibatch:0,1 * rnnbidirectional:1 * rnnSkipInput:0 * rnnPersistent:2 * rnnTestDropout:0,1 * mode:0,1 * Pmath:0,1
    //pattern: .*rnnbidirectional1.*rnnSkipInput1.*rnnPersistent2.*rnnTestDropout0.*mode0.* total 32 cases
    rnnInputSize:1024 * rnnNumLayers:2 * rnnMiniBatch:48 * rnnSeqLength:2 * rnnHiddenSize:1024 * rnnTestVariableMinibatch:0,1 * rnnbidirectional:1 * rnnSkipInput:1 * rnnPersistent:2 * rnnTestDropout:0 * mode:0,1 * Pmath:0,1

//RNN find support-2
<L4_RNN_find_2:L4>
    //pattern: .*rnnbidirectional0.*rnnPersistent0.*rnnTestDropout0.*mode2.* total 32 cases
    rnnInputSize:1024 * rnnNumLayers:2 * rnnMiniBatch:48 * rnnSeqLength:2 * rnnHiddenSize:1024 * rnnTestVariableMinibatch:0,1 * rnnbidirectional:0 * rnnSkipInput:0,1 * rnnPersistent:0 * rnnTestDropout:0 * mode:2 * Pmath:0,1
