    padA:"0,2,0" * dim:3 * dimA:"8,5,4,3,2"  * groupCount:5 * filtA:"15,1,2,3,1"
    padA:"2,1,2" * dim:3 * dimA:"2,4,7,6,4" * groupCount:2 * filtA:"16,2,8,5,4"

<L3_groupedConv_nhwc:L3,L4>
